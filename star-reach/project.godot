; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[android]

gradle_build/use_gradle_build=true

[application]

config/name="StarReach"
config/version="1.0.0"
run/main_scene="res://scenes/splash/splash.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.06, 0.08, 0.18, 1)
config/icon="res://icon.svg"
boot_splash/minimum_display_time=500

[audio]

buses/default_bus_layout="res://assets/audio/default_bus_layout.tres"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
LocaleService="*res://scripts/autoload/locale_service.gd"
GameState="*res://scripts/autoload/game_state.gd"
TimeManager="*res://scripts/autoload/time_manager.gd"
IAPService="*res://scripts/autoload/iap_service.gd"
SaveSystem="*res://scripts/autoload/save_system.gd"
SoundService="*res://scripts/autoload/sound_service.gd"
AdService="*res://scripts/autoload/ad_service.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/GodotGooglePlayBilling/plugin.cfg", "res://addons/godotsteam/plugin.cfg")

[gui]

theme/default_theme_scale=1.5
theme/custom="res://assets/theme/main_theme.tres"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

[steam]

initialization/app_id=0
initialization/initialize_on_startup=false
initialization/embed_callbacks=false
multiplayer_peer/max_channels=4
